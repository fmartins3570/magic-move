<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files from dist/ directly
  RewriteCond %{DOCUMENT_ROOT}/%{HTTP_HOST}/dist%{REQUEST_URI} -f
  RewriteRule ^(.*)$ dist/$1 [L]

  # Everything else goes through index.php (SPA handler)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.php [L]
</IfModule>

DirectoryIndex index.php
